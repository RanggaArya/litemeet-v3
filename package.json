{
  "name": "litemeet-vercel",
  "version": "0.2.0",
  "private": true,
  "main": "main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "dev:desktop": "concurrently -n \"NEXT,ELECTRON\" -c \"magenta,blue\" \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "build:electron": "electron-builder build --win --x64 -c.extraMetadata.main=main.js",
    "pack:desktop": "npm run build:electron"
  },
  "build": {
    "appId": "com.litemeet.app",
    "productName": "LiteMeet",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "public/icon.png",
      "main.js",
      "preload.js",
      "package.json"
    ],
    "asarUnpack": [
      "public/icon.png"
    ],
    "win": {
      "icon": "public/icon.png",
      "target": [
        "nsis"
      ]
    },
    "compression": "store",
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "@livekit/components-react": "^2.9.19",
    "@livekit/components-styles": "^1.2.0",
    "firebase": "^12.14.0",
    "livekit-client": "^2.17.0",
    "livekit-server-sdk": "^2.15.0",
    "nanoid": "^5.1.11",
    "next": "16.1.4",
    "pusher": "^5.3.2",
    "pusher-js": "^8.4.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "twilio": "^5.12.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "babel-plugin-react-compiler": "1.0.0",
    "concurrently": "^9.2.1",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.4",
    "tailwindcss": "^4",
    "wait-on": "^9.0.5"
  }
}
